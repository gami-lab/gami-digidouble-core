# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─────────────────────────────────────────────
# Database (PostgreSQL + pgvector)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gami_core
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─────────────────────────────────────────────
# Cache / Session (Redis)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# API Authentication
# ─────────────────────────────────────────────
API_KEY_SECRET=change_me_in_production

# ─────────────────────────────────────────────
# LLM Providers — add the providers you use
# ─────────────────────────────────────────────
LLM_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=

# ─────────────────────────────────────────────
# Observability (Langfuse — self-hosted preferred)
# ─────────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3030
